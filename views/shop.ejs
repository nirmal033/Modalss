<%- include('./partials/header') %>

    <div class="container-fluid px-4 mt-3">
        <% if (error && error.length> 0) { %>
            <div class="alert-flash-error d-flex align-items-center justify-content-between p-3 mb-4" role="alert">
                <div class="d-flex align-items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor"
                        class="bi bi-exclamation-triangle-fill flex-shrink-0" viewBox="0 0 16 16">
                        <path
                            d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5m.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2" />
                    </svg>
                    <span class="flash-message-text small fw-medium">
                        <%= error[0] %>
                    </span>
                </div>
            </div>
            <% } %>

                <% if (success && success.length> 0) { %>
                    <div class="alert-flash-success d-flex align-items-center justify-content-between p-3 mb-4"
                        role="alert">
                        <div class="d-flex align-items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor"
                                class="bi bi-check-circle-fill flex-shrink-0" viewBox="0 0 16 16">
                                <path
                                    d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0m-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z" />
                            </svg>
                            <span class="flash-success-text small fw-medium">
                                <%= success[0] %>
                            </span>
                        </div>
                    </div>
                    <% } %>
    </div>

    <div class="container-fluid px-4 my-4">
        <div class="row g-4">

            <aside class="col-12 col-lg-3">
                <div class="filter-sidebar">
                    <div class="sidebar-title mb-4">Filters</div>

                    <form action="/shop/search" method="GET" class="mb-4">
                        <label class="filter-label">Search Products</label>
                        <div class="search-input-wrap">
                            <input type="text" name="query" class="form-control-custom-shop"
                                placeholder="Type to search...">
                            <button type="submit" class="search-btn">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                                    viewBox="0 0 16 16">
                                    <path
                                        d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0" />
                                </svg>
                            </button>
                        </div>
                    </form>

                    <hr class="filter-divider">

                    <div class="mb-4">
                        <label class="filter-label">Categories</label>
                        <div class="d-flex flex-column gap-2 mt-2">
                            <label class="custom-check-shop">
                                <input type="checkbox" name="category" value="electronics" checked>
                                <span class="check-box-shop"></span>
                                <span class="check-label-text">Electronics</span>
                            </label>
                            <label class="custom-check-shop">
                                <input type="checkbox" name="category" value="apparel">
                                <span class="check-box-shop"></span>
                                <span class="check-label-text">Apparel & Bags</span>
                            </label>
                        </div>
                    </div>

                    <hr class="filter-divider">

                    <div class="mb-2">
                        <label class="filter-label">Price Range</label>
                        <div class="variant-select-wrapper mt-2">
                            <select name="price_range" class="product-select w-100">
                                <option value="all">All Prices</option>
                                <option value="0-50">$0 - $50</option>
                                <option value="50-150">$50 - $150</option>
                            </select>
                        </div>
                    </div>
                </div>
            </aside>

            <main class="col-12 col-lg-9">

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <p class="text-muted small mb-0">Showing 1–2 of 32 entries</p>
                    <div class="d-flex align-items-center gap-2">
                        <span class="small text-muted text-nowrap">Sort by:</span>
                        <select class="product-select py-1">
                            <option>Latest Items</option>
                            <option>Price: Low to High</option>
                        </select>
                    </div>
                </div>

                <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-xl-4 g-3">
                    <% products.forEach(function(product){ %>
                        <div class="col">
                            <form action="/cart/add/<%= product._id %>" method="POST" class="product-card sub-compact">
                                <div class="product-img-wrapper">
                                    <img src="data:<%= product.image.contentType %>;base64,<%= product.image.data.toString('base64') %>"
                                        alt="<%= product.name %>" class="product-img">
                                </div>
                                <div class="product-info p-3">
                                    <h3 class="product-name small-title">
                                        <%= product.name %>
                                    </h3>
                                    <div class="product-meta my-2 d-flex flex-column gap-2">
                                        <span class="product-price small-price">
                                            ₹ <%= product.price %>
                                        </span>
                                    </div>
                                    <button type="submit" class="btn-product-submit compact-btn mt-1">
                                        <span>Add To Cart</span>
                                    </button>
                                </div>
                            </form>
                        </div>
                        <% }) %>
                </div>

                <nav class="d-flex justify-content-center mt-5">
                    <ul class="pagination-custom">
                        <li class="page-item-custom disabled"><a href="#">&laquo;</a></li>
                        <li class="page-item-custom active"><a href="#">1</a></li>
                        <li class="page-item-custom"><a href="#">2</a></li>
                        <li class="page-item-custom"><a href="#">&raquo;</a></li>
                    </ul>
                </nav>

            </main>
        </div>
    </div>

    <%- include('./partials/footer') %>