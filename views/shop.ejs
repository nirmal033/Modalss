<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Modalss — Shop</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Custom base -->
    <link rel="stylesheet" href="/stylesheets/shop.css" />

</head>

<body>

    <!-- ═══════════════ NAV ═══════════════ -->
    <nav class="shop-nav">
        <a href="/" class="nav-brand">
            <img src="/images/modalss-logo-withoutname.png" alt="Modalss" />
            <span class="nav-brand-name">Modalss</span>
        </a>

        <div class="nav-links">
            <a href="#" class="nav-link-item active">Shop</a>
            <a href="#" class="nav-link-item">New In</a>
            <a href="#" class="nav-link-item">Collections</a>
            <a href="#" class="nav-link-item">Sale</a>
        </div>

        <div class="nav-actions">
            <!-- Search -->
            <a href="#" class="nav-icon-btn" title="Search">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                    stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8" />
                    <line x1="21" y1="21" x2="16.65" y2="16.65" />
                </svg>
            </a>
            <!-- Wishlist -->
            <a href="#" class="nav-icon-btn" title="Wishlist">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                    stroke-linecap="round" stroke-linejoin="round">
                    <path
                        d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
                </svg>
            </a>
            <!-- Cart -->
            <a href="#" class="nav-icon-btn" title="Cart" style="position:relative">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                    stroke-linecap="round" stroke-linejoin="round">
                    <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" />
                    <line x1="3" y1="6" x2="21" y2="6" />
                    <path d="M16 10a4 4 0 0 1-8 0" />
                </svg>
                <span class="cart-badge">3</span>
            </a>
            <!-- Account -->
            <!-- Account -->
            <a href="/profile" class="nav-icon-btn" title="Account">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                    stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                    <circle cx="12" cy="7" r="4" />
                </svg>
            </a>

            <!-- Logout -->
            <a href="/users/logout" class="logout-btn" title="Logout">
                Logout
            </a>
        </div>
    </nav>

    <!-- ═══════════════ HERO ═══════════════ -->
    <section class="shop-hero">
        <div style="position:relative;z-index:1">
            <span class="shop-hero-eyebrow">Summer 2026 Collection</span>
            <h1 class="shop-hero-title">Dress the Story You're Living</h1>
            <p class="shop-hero-sub">Curated pieces that move with you — from morning light to midnight.</p>
            <div class="hero-stats">
                <div class="hero-stat">
                    <div class="hero-stat-num">240+</div>
                    <div class="hero-stat-label">Styles</div>
                </div>
                <div class="hero-stat">
                    <div class="hero-stat-num">18</div>
                    <div class="hero-stat-label">New drops</div>
                </div>
                <div class="hero-stat">
                    <div class="hero-stat-num">Up to 40%</div>
                    <div class="hero-stat-label">Off sale items</div>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══════════════ LAYOUT ═══════════════ -->
    <div class="shop-layout">

        <!-- ════════ SIDEBAR ════════ -->
        <aside class="sidebar">

            <!-- Category Filter -->
            <div class="filter-card">
                <div class="filter-card-head">
                    <span class="filter-card-title">Categories</span>
                </div>
                <div class="filter-card-body">

                    <input class="filter-radio" type="radio" name="cat" id="cat-all" checked />
                    <label class="filter-option" for="cat-all">
                        All Products
                        <span class="filter-count">240</span>
                    </label>

                    <input class="filter-radio" type="radio" name="cat" id="cat-new" />
                    <label class="filter-option" for="cat-new">
                        New Collection
                        <span class="filter-count">18</span>
                    </label>

                    <input class="filter-radio" type="radio" name="cat" id="cat-disc" />
                    <label class="filter-option" for="cat-disc">
                        Discounted
                        <span class="filter-count">56</span>
                    </label>

                    <input class="filter-radio" type="radio" name="cat" id="cat-women" />
                    <label class="filter-option" for="cat-women">
                        Women's
                        <span class="filter-count">98</span>
                    </label>

                    <input class="filter-radio" type="radio" name="cat" id="cat-men" />
                    <label class="filter-option" for="cat-men">
                        Men's
                        <span class="filter-count">74</span>
                    </label>

                    <input class="filter-radio" type="radio" name="cat" id="cat-acc" />
                    <label class="filter-option" for="cat-acc">
                        Accessories
                        <span class="filter-count">50</span>
                    </label>

                </div>
            </div>

            <!-- Availability Filter -->
            <div class="filter-card">
                <div class="filter-card-head">
                    <span class="filter-card-title">Availability</span>
                </div>
                <div class="filter-card-body">

                    <input class="filter-check" type="checkbox" id="avail-instock" checked />
                    <label class="check-option" for="avail-instock">
                        <span class="check-visual"></span>
                        In Stock
                    </label>

                    <input class="filter-check" type="checkbox" id="avail-preorder" />
                    <label class="check-option" for="avail-preorder">
                        <span class="check-visual"></span>
                        Pre-order
                    </label>

                    <input class="filter-check" type="checkbox" id="avail-soldout" />
                    <label class="check-option" for="avail-soldout">
                        <span class="check-visual"></span>
                        Out of Stock
                    </label>

                </div>
            </div>

            <!-- Discount Filter -->
            <div class="filter-card">
                <div class="filter-card-head">
                    <span class="filter-card-title">Discount</span>
                </div>
                <div class="filter-card-body">

                    <input class="filter-check" type="checkbox" id="disc-10" />
                    <label class="check-option" for="disc-10">
                        <span class="check-visual"></span>
                        10% and above
                    </label>

                    <input class="filter-check" type="checkbox" id="disc-20" checked />
                    <label class="check-option" for="disc-20">
                        <span class="check-visual"></span>
                        20% and above
                    </label>

                    <input class="filter-check" type="checkbox" id="disc-30" />
                    <label class="check-option" for="disc-30">
                        <span class="check-visual"></span>
                        30% and above
                    </label>

                    <input class="filter-check" type="checkbox" id="disc-40" />
                    <label class="check-option" for="disc-40">
                        <span class="check-visual"></span>
                        40% and above
                    </label>

                </div>
            </div>

            <!-- Price Range (visual, decorative) -->
            <div class="filter-card">
                <div class="filter-card-head">
                    <span class="filter-card-title">Price Range</span>
                </div>
                <div class="filter-card-body">
                    <div class="price-range-display">
                        <div class="price-range-track">
                            <div class="price-range-thumb"></div>
                        </div>
                        <div class="price-range-labels">
                            <span>₹499</span>
                            <span>₹8,999</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sidebar Promo -->
            <div class="sidebar-promo">
                <div class="sidebar-promo-title">SUMMER SALE</div>
                <p class="sidebar-promo-sub">Up to 40% off on select styles. Limited time only.</p>
                <a href="#" class="sidebar-promo-btn">Shop the Sale →</a>
            </div>

        </aside>

        <!-- ════════ MAIN ════════ -->
        <main class="shop-main">

            <!-- Toolbar -->
            <div class="shop-toolbar">
                <div class="toolbar-left">
                    <p class="result-count"><strong>240</strong> products found</p>
                </div>

                <!-- Sort pills -->
                <div class="sort-group">
                    <input class="sort-radio" type="radio" name="sort" id="sort-pop" checked />
                    <label class="sort-label" for="sort-pop">
                        ✦ Popular
                    </label>

                    <input class="sort-radio" type="radio" name="sort" id="sort-new" />
                    <label class="sort-label" for="sort-new">
                        ★ Newest
                    </label>

                    <input class="sort-radio" type="radio" name="sort" id="sort-plo" />
                    <label class="sort-label" for="sort-plo">
                        ↑ Price
                    </label>

                    <input class="sort-radio" type="radio" name="sort" id="sort-phi" />
                    <label class="sort-label" for="sort-phi">
                        ↓ Price
                    </label>
                </div>

                <!-- View toggle -->
                <div class="view-toggle">
                    <input class="view-radio" type="radio" name="view" id="view-grid" checked />
                    <label class="view-btn" for="view-grid" title="Grid view">
                        <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor">
                            <rect x="0" y="0" width="6" height="6" rx="1.5" />
                            <rect x="10" y="0" width="6" height="6" rx="1.5" />
                            <rect x="0" y="10" width="6" height="6" rx="1.5" />
                            <rect x="10" y="10" width="6" height="6" rx="1.5" />
                        </svg>
                    </label>

                    <input class="view-radio" type="radio" name="view" id="view-list" />
                    <label class="view-btn" for="view-list" title="List view">
                        <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor">
                            <rect x="0" y="0" width="16" height="3.5" rx="1.5" />
                            <rect x="0" y="6.25" width="16" height="3.5" rx="1.5" />
                            <rect x="0" y="12.5" width="16" height="3.5" rx="1.5" />
                        </svg>
                    </label>
                </div>
            </div>

            <!-- Active filters -->
            <div class="active-filters">
                <span class="active-filter-label">Active:</span>
                <span class="filter-tag">All Products ✕</span>
                <span class="filter-tag">In Stock ✕</span>
                <span class="filter-tag">20%+ Off ✕</span>
            </div>

            <!-- ════ PRODUCT GRID ════ -->

            <div class="section-heading">New Arrivals</div>
            <div class="product-grid" style="margin-bottom:2rem">

                <!-- Card 1 -->
                <div class="product-card">
                    <div class="card-img-wrap">
                        <img src="https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?w=400&q=80"
                            alt="Bloom Sundress" />
                        <div class="card-badges">
                            <span class="badge-pill badge-new">New</span>
                            <span class="badge-pill badge-hot">🔥 Hot</span>
                        </div>
                        <a href="#" class="wishlist-btn" title="Wishlist">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <path
                                    d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
                            </svg>
                        </a>
                        <div class="quick-add-overlay">
                            <a href="#" class="quick-add-btn">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" />
                                    <line x1="3" y1="6" x2="21" y2="6" />
                                    <path d="M16 10a4 4 0 0 1-8 0" />
                                </svg>
                                Quick Add
                            </a>
                            <a href="#" class="quick-cart-btn" title="Add to cart">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <line x1="12" y1="5" x2="12" y2="19" />
                                    <line x1="5" y1="12" x2="19" y2="12" />
                                </svg>
                            </a>
                        </div>
                    </div>
                    <div class="card-body-content">
                        <span class="card-category">Women · Dresses</span>
                        <p class="card-name">Bloom Wrap Sundress</p>
                        <div class="card-swatches">
                            <span class="swatch" style="background:#E8649A" title="Pink"></span>
                            <span class="swatch" style="background:#7B6FD4" title="Lavender"></span>
                            <span class="swatch" style="background:#F5E6C8" title="Cream"></span>
                        </div>
                        <div class="card-rating">
                            <span class="stars">★★★★★</span>
                            <span>4.9 (312)</span>
                        </div>
                        <div class="card-price-row">
                            <span class="price-current">₹2,199</span>
                        </div>
                    </div>
                    <div class="card-footer-bar">
                        <a href="#" class="btn-add-cart">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" />
                                <line x1="3" y1="6" x2="21" y2="6" />
                                <path d="M16 10a4 4 0 0 1-8 0" />
                            </svg>
                            Add to Cart
                        </a>
                        <a href="#" class="btn-wishlist-bottom" title="Save">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <path
                                    d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
                            </svg>
                        </a>
                    </div>
                </div>

                <!-- Card 2 — Sale -->
                <div class="product-card">
                    <div class="card-img-wrap">
                        <img src="https://images.unsplash.com/photo-1529139574466-a303027c1d8b?w=400&q=80"
                            alt="Linen Co-ord" />
                        <div class="card-badges">
                            <span class="badge-pill badge-sale">−30%</span>
                        </div>
                        <a href="#" class="wishlist-btn" title="Wishlist">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <path
                                    d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
                            </svg>
                        </a>
                        <div class="quick-add-overlay">
                            <a href="#" class="quick-add-btn">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" />
                                    <line x1="3" y1="6" x2="21" y2="6" />
                                    <path d="M16 10a4 4 0 0 1-8 0" />
                                </svg>
                                Quick Add
                            </a>
                            <a href="#" class="quick-cart-btn">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <line x1="12" y1="5" x2="12" y2="19" />
                                    <line x1="5" y1="12" x2="19" y2="12" />
                                </svg>
                            </a>
                        </div>
                    </div>
                    <div class="card-body-content">
                        <span class="card-category">Women · Co-ords</span>
                        <p class="card-name">Desert Linen Co-ord Set</p>
                        <div class="card-swatches">
                            <span class="swatch" style="background:#D4A96A" title="Sand"></span>
                            <span class="swatch" style="background:#6B8F71" title="Sage"></span>
                            <span class="swatch" style="background:#2C2C3A" title="Midnight"></span>
                        </div>
                        <div class="card-rating">
                            <span class="stars">★★★★☆</span>
                            <span>4.6 (189)</span>
                        </div>
                        <div class="card-price-row">
                            <span class="price-current">₹3,149</span>
                            <span class="price-original">₹4,499</span>
                            <span class="price-discount">−30%</span>
                        </div>
                    </div>
                    <div class="card-footer-bar">
                        <a href="#" class="btn-add-cart">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" />
                                <line x1="3" y1="6" x2="21" y2="6" />
                                <path d="M16 10a4 4 0 0 1-8 0" />
                            </svg>
                            Add to Cart
                        </a>
                        <a href="#" class="btn-wishlist-bottom">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <path
                                    d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
                            </svg>
                        </a>
                    </div>
                </div>

                <!-- Card 3 -->
                <div class="product-card">
                    <div class="card-img-wrap">
                        <img src="https://images.unsplash.com/photo-1544441893-675973e31985?w=400&q=80"
                            alt="Oversized Blazer" />
                        <div class="card-badges">
                            <span class="badge-pill badge-new">New</span>
                        </div>
                        <a href="#" class="wishlist-btn" title="Wishlist">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <path
                                    d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
                            </svg>
                        </a>
                        <div class="quick-add-overlay">
                            <a href="#" class="quick-add-btn">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" />
                                    <line x1="3" y1="6" x2="21" y2="6" />
                                    <path d="M16 10a4 4 0 0 1-8 0" />
                                </svg>
                                Quick Add
                            </a>
                            <a href="#" class="quick-cart-btn">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <line x1="12" y1="5" x2="12" y2="19" />
                                    <line x1="5" y1="12" x2="19" y2="12" />
                                </svg>
                            </a>
                        </div>
                    </div>
                    <div class="card-body-content">
                        <span class="card-category">Women · Blazers</span>
                        <p class="card-name">Oversized Power Blazer</p>
                        <div class="card-swatches">
                            <span class="swatch" style="background:#1A1733" title="Black"></span>
                            <span class="swatch" style="background:#C0C0C0" title="Silver"></span>
                            <span class="swatch" style="background:#9B2F1A" title="Rust"></span>
                        </div>
                        <div class="card-rating">
                            <span class="stars">★★★★★</span>
                            <span>5.0 (47)</span>
                        </div>
                        <div class="card-price-row">
                            <span class="price-current">₹4,799</span>
                        </div>
                    </div>
                    <div class="card-footer-bar">
                        <a href="#" class="btn-add-cart">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" />
                                <line x1="3" y1="6" x2="21" y2="6" />
                                <path d="M16 10a4 4 0 0 1-8 0" />
                            </svg>
                            Add to Cart
                        </a>
                        <a href="#" class="btn-wishlist-bottom">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <path
                                    d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
                            </svg>
                        </a>
                    </div>
                </div>

                <!-- Card 4 — Out of Stock -->
                <div class="product-card card-soldout">
                    <div class="card-img-wrap">
                        <img src="https://images.unsplash.com/photo-1591047139829-d91aecb6caea?w=400&q=80"
                            alt="Puffer Jacket" />
                        <div class="card-badges">
                            <span class="badge-pill badge-soldout">Sold Out</span>
                        </div>
                        <a href="#" class="wishlist-btn">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor"
