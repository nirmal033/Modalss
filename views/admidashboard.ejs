<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Modalss Admin</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/stylesheets/admin.css">
</head>

<body>

    <div class="admin-wrapper">

        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="logo">
                <h2>MODALSS</h2>
                <span>Admin Panel</span>
            </div>

            <nav>
                <a href="#" class="active">Dashboard</a>
                <a href="#">Products</a>
                <a href="#">Orders</a>
                <a href="#">Users</a>
                <a href="#">Analytics</a>
            </nav>
        </aside>

        <!-- Main -->
        <main class="content">

            <div class="topbar">
                <h1>Products</h1>

                <a href="/owners/admin/create" class="create-btn">
                    + Create Product
                </a>
            </div>

            <!-- Stats -->
            <div class="stats-grid">

                <div class="stat-card">
                    <h3>240</h3>
                    <p>Total Products</p>
                </div>

                <div class="stat-card">
                    <h3>₹3.4L</h3>
                    <p>Total Revenue</p>
                </div>

                <div class="stat-card">
                    <h3>89</h3>
                    <p>Orders Today</p>
                </div>

                <div class="stat-card">
                    <h3>32</h3>
                    <p>Low Stock</p>
                </div>

            </div>

            <!-- Search -->
            <div class="table-header">
                <input type="text" placeholder="Search products...">
            </div>

            <!-- Table -->
            <div class="table-container">

                <table>

                    <thead>
                        <tr>
                            <th>Image</th>
                            <th>Product</th>
                            <th>Category</th>
                            <th>Price</th>
                            <th>Discount</th>
                            <th>Stock</th>
                            <th>Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        <% products.forEach(function(product){%>
                            <tr>
                                <td>
                                    <img src="data:<%= product.image.contentType %>;base64,<%= product.image.data.toString('base64') %>"
                                        class="product-img">
                                </td>

                                <td>
                                    <%=product.name%>
                                </td>
                                <td>
                                    <%=product.category%>
                                </td>
                                <td>
                                    <%= product.price%>
                                </td>
                                <td>
                                    <%=product.discount%>
                                </td>
                                <td>
                                    <%=product.stock%>
                                </td>

                                <td>
                                    <button class="btn-view">View</button>
                                    <button class="btn-edit">Edit</button>
                                    <button class="btn-delete">Delete</button>
                                </td>
                            </tr>
                            <%})%>

                    </tbody>

                </table>

            </div>

        </main>

    </div>

</body>

</html>