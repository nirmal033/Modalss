<%- include('./partials/header') %>

    <main class="container-fluid px-4 my-4">
        <% if (error && error.length> 0) { %>
            <div class="alert-flash-error d-flex align-items-center justify-content-between p-3 mb-4" role="alert">
                <div class="d-flex align-items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor"
                        class="bi bi-exclamation-triangle-fill flex-shrink-0" viewBox="0 0 16 16">
                        <path
                            d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5m.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2" />
                    </svg>
                    <span class="flash-message-text small fw-medium">
                        <%= error[0] %>
                    </span>
                </div>
            </div>
            <% } %>

                <% if (success && success.length> 0) { %>
                    <div class="alert-flash-success d-flex align-items-center justify-content-between p-3 mb-4"
                        role="alert">
                        <div class="d-flex align-items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor"
                                class="bi bi-check-circle-fill flex-shrink-0" viewBox="0 0 16 16">
                                <path
                                    d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0m-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z" />
                            </svg>
                            <span class="flash-success-text small fw-medium">
                                <%= success[0] %>
                            </span>
                        </div>
                    </div>
                    <% } %>
                        <div class="text-start mb-4">
                            <span class="shop-greeting">Your Basket</span>
                            <h1 class="shop-title mt-2">Shopping Cart</h1>
                        </div>

                        <% if (cart && cart.products.length> 0) { %>
                            <form action="/cart/update" method="POST" class="row g-4">

                                <div class="col-12 col-lg-8">
                                    <div class="cart-items-wrapper">

                                        <% cart.products.forEach(function(product, index) { %>
                                            <div
                                                class="cart-item-row d-flex align-items-center flex-wrap py-3 border-bottom">

                                                <div class="cart-img-wrap col-3 col-sm-2 col-md-2 mb-2 mb-sm-0">
                                                    <img src="data:<%= product.productId.image.contentType %>;base64,<%= product.productId.image.data.toString('base64') %>"
                                                        alt="<%= product.productId.name %>" class="img-fluid rounded">
                                                </div>

                                                <div
                                                    class="cart-details-wrap col-9 col-sm-4 col-md-5 ps-3 mb-2 mb-sm-0">
                                                    <h4 class="cart-item-title mb-1">
                                                        <%= product.productId.name %>
                                                    </h4>
                                                    <p class="cart-item-meta mb-0 text-muted small">Variant: <span
                                                            class="fw-medium">Standard</span></p>

                                                    <input type="hidden" name="items[<%= index %>][product_id]"
                                                        value="<%= product.productId._id %>">
                                                </div>

                                                <div class="cart-price-wrap col-4 col-sm-2 text-sm-center">
                                                    <span class="cart-item-price">
                                                        ₹<%= product.productId.price %>
                                                    </span>
                                                </div>

                                                <div class="cart-qty-wrap col-4 col-sm-2 text-center">
                                                    <input type="number" name="items[<%= index %>][quantity]"
                                                        class="form-control form-control-custom-shop text-center py-1 mx-auto"
                                                        value="<%= product.quantity %>" min="1" max="99"
                                                        style="max-width: 70px; border: 1px solid var(--border-soft);">
                                                </div>

                                                <div class="cart-action-wrap col-4 col-sm-2 text-end">
                                                    <button type="submit"
                                                        formaction="/cart/remove/<%= product.productId._id %>"
                                                        class="btn btn-transparent text-muted cart-remove-btn p-2"
                                                        title="Remove Item">
                                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                                                            fill="currentColor" class="bi bi-trash3"
                                                            viewBox="0 0 16 16">
                                                            <path
                                                                d="M6.5 1h3a.5.5 0 0 1 .5.5v1H6v-1a.5.5 0 0 1 .5-.5M11 2.5v-1A1.5 1.5 0 0 0 9.5 0h-3A1.5 1.5 0 0 0 5 1.5v1H1.5a.5.5 0 0 0 0 1h.538l.853 10.66A2 2 0 0 0 4.991 16h6.018a2 2 0 0 0 1.996-1.84l.853-10.66h.538a.5.5 0 0 0 0-1zm1.958 1-.846 10.58a1 1 0 0 1-.997.92H4.991a1 1 0 0 1-.997-.92L3.042 3.5zm-7.487 1a.5.5 0 0 1 .528.47l.5 8.5a.5.5 0 0 1-.998.06L5 5.03a.5.5 0 0 1 .47-.53Zm5.058 0a.5.5 0 0 1 .47.53l-.5 8.5a.5.5 0 1 1-.998-.06l.5-8.5a.5.5 0 0 1 .528-.47M8 4.5a.5.5 0 0 1 .5.5v8.5a.5.5 0 0 1-1 0V5a.5.5 0 0 1 .5-.5" />
                                                        </svg>
                                                    </button>
                                                </div>
                                            </div>
                                            <% }) %>

                                                <div class="d-flex justify-content-between align-items-center mt-4">
                                                    <a href="/users/shop"
                                                        class="text-decoration-none small fw-semibold link-forgot d-inline-flex align-items-center gap-1">
                                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                                                            fill="currentColor" viewBox="0 0 16 16">
                                                            <path fill-rule="evenodd"
                                                                d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8" />
                                                        </svg>
                                                        Continue Shopping
                                                    </a>
                                                    <button type="submit"
                                                        class="btn btn-outline-purple-custom py-2 px-3 small fw-semibold">
                                                        Update Quantities
                                                    </button>
                                                </div>

                                    </div>
                                </div>

                                <div class="col-12 col-lg-4">
                                    <div class="cart-summary-sidebar p-4">
                                        <h3 class="sidebar-title mb-4">Summary</h3>

                                        <div class="d-flex justify-content-between mb-2">
                                            <span class="text-muted small">Subtotal</span>
                                            <span class="text-dark fw-medium small">₹<%= cart.bill %></span>
                                        </div>
                                        <div class="d-flex justify-content-between mb-3">
                                            <span class="text-muted small">Estimated Shipping</span>
                                            <span class="text-success small fw-medium">Free</span>
                                        </div>

                                        <hr class="filter-divider">

                                        <div class="d-flex justify-content-between align-items-center mb-4">
                                            <span class="text-dark fw-semibold font-outfit">Total Amount</span>
                                            <span class="cart-item-price fs-3">₹<%= cart.bill %></span>
                                        </div>

                                        <button type="submit" formaction="/checkout"
                                            class="btn-product-submit w-100 py-3">
                                            <span>Proceed to Checkout</span>
                                        </button>
                                    </div>
                                </div>

                            </form>
                            <% } else { %>
                                <div class="text-center py-5 background-card-custom rounded p-4">
                                    <p class="text-muted mb-3">Your shopping cart is currently empty.</p>
                                    <a href="/users/shop"
                                        class="btn btn-outline-purple-custom px-4 py-2 small fw-semibold">Discover
                                        Products</a>
                                </div>
                                <% } %>
    </main>

    <%- include('./partials/footer') %>