<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Modalss — Create Account</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/stylesheets/styles.css" />

    <style>
        /* Register-specific overrides */
        .brand-panel {
            background: linear-gradient(145deg, #9B2F1A 0%, #C44028 40%, #7B3FA0 100%);
        }

        .brand-tagline-reg {
            font-size: 0.9rem;
            color: rgba(255, 255, 255, 0.65);
            letter-spacing: 0.04em;
            margin-bottom: 2.5rem;
            line-height: 1.7;
            max-width: 280px;
        }

        .perks {
            list-style: none;
            padding: 0;
            margin: 0 0 3rem;
            display: flex;
            flex-direction: column;
            gap: 0.9rem;
        }

        .perks li {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            color: rgba(255, 255, 255, 0.85);
            font-size: 0.88rem;
            font-weight: 400;
        }

        .perk-icon {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.15);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            font-size: 0.85rem;
        }

        /* Section divider inside form */
        .form-section-title {
            font-family: 'Outfit', sans-serif;
            font-size: 0.75rem;
            font-weight: 700;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--text-muted);
            margin: 1.5rem 0 1rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .form-section-title::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--border-soft);
        }
    </style>
</head>

<body>

    <div class="page-wrapper">

        <!-- ── Left: Brand Panel ── -->
        <aside class="brand-panel">
            <div class="orb orb-1"></div>
            <div class="orb orb-2"></div>
            <div class="orb orb-3"></div>

            <div class="brand-content">
                <div class="brand-logo-wrap">
                    <img src="/images/modalss-logo-withoutname.png" alt="Modalss Logo" />
                </div>
                <h1 class="brand-name">Modalss</h1>
                <p class="brand-tagline-reg">Join thousands who discover fashion that fits their unique identity.</p>

                <ul class="perks">
                    <li>
                        <span class="perk-icon">✦</span>
                        Curated collections updated weekly
                    </li>
                    <li>
                        <span class="perk-icon">⚡</span>
                        Exclusive member-only deals &amp; drops
                    </li>
                    <li>
                        <span class="perk-icon">🎨</span>
                        Personalised style recommendations
                    </li>
                    <li>
                        <span class="perk-icon">🛍️</span>
                        Fast, free delivery on first order
                    </li>
                </ul>

                <div class="dots-grid">
                    <div class="dot" style="animation-delay:0.00s"></div>
                    <div class="dot" style="animation-delay:0.06s"></div>
                    <div class="dot" style="animation-delay:0.12s"></div>
                    <div class="dot" style="animation-delay:0.18s"></div>
                    <div class="dot" style="animation-delay:0.24s"></div>
                    <div class="dot" style="animation-delay:0.30s"></div>
                    <div class="dot" style="animation-delay:0.36s"></div>
                    <div class="dot" style="animation-delay:0.42s"></div>
                    <div class="dot" style="animation-delay:0.48s"></div>
                    <div class="dot" style="animation-delay:0.54s"></div>
                    <div class="dot" style="animation-delay:0.60s"></div>
                    <div class="dot" style="animation-delay:0.66s"></div>
                    <div class="dot" style="animation-delay:0.72s"></div>
                    <div class="dot" style="animation-delay:0.78s"></div>
                    <div class="dot" style="animation-delay:0.84s"></div>
                </div>
            </div>
        </aside>

        <!-- ── Right: Form Panel ── -->
        <main class="form-panel">
            <div class="auth-card">

                <!-- Mobile logo -->
                <div class="mobile-logo">
                    <img src="modalss-logo.jpeg" alt="Modalss" />
                    <div class="brand-name-sm">Modalss</div>
                </div>

                <div class="auth-card-header">
                    <span class="auth-greeting">New here?</span>
                    <h2 class="auth-title">Create your account</h2>
                    <p class="auth-subtitle">Fill in the details below to get started.</p>
                </div>
                <% if(error.length>0) { %>
                    <!-- Error Message Here -->
                    <div class="error-box">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="12" y1="8" x2="12" y2="12"></line>
                            <line x1="12" y1="16" x2="12.01" y2="16"></line>
                        </svg>

                        <span>
                            <%= error%>
                        </span>
                    </div>
                    <% }%>

                        <!-- Register Form -->
                        <form action="#" method="POST">

                            <!-- ── Personal Info ── -->
                            <div class="form-section-title">Personal info</div>

                            <div class="name-row">
                                <div class="form-group">
                                    <label class="form-label" for="firstName">Full name</label>
                                    <div class="input-wrap">
                                        <svg class="input-icon" width="16" height="16" viewBox="0 0 24 24" fill="none"
                                            stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                            stroke-linejoin="round">
                                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                                            <circle cx="12" cy="7" r="4" />
                                        </svg>
                                        <input type="text" id="firstName" name="firstName" class="form-control-custom"
                                            placeholder="Kinjal Vachheta" required />
                                    </div>
                                </div>
                            </div>

                            <div class="form-group">
                                <label class="form-label" for="regEmail">Email address</label>
                                <div class="input-wrap">
                                    <svg class="input-icon" width="16" height="16" viewBox="0 0 24 24" fill="none"
                                        stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                        stroke-linejoin="round">
                                        <path
                                            d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                                        <polyline points="22,6 12,13 2,6" />
                                    </svg>
                                    <input type="email" id="regEmail" name="email" class="form-control-custom"
                                        placeholder="hello@modalss.com" autocomplete="email" required />
                                </div>
                            </div>

                            <div class="form-group">
                                <label class="form-label" for="phone">
                                    Phone <span style="color:var(--text-muted);font-weight:400">(optional)</span>
                                </label>
                                <div class="input-wrap">
                                    <svg class="input-icon" width="16" height="16" viewBox="0 0 24 24" fill="none"
                                        stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                        stroke-linejoin="round">
                                        <path
                                            d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13 19.79 19.79 0 0 1 1.61 4.4 2 2 0 0 1 3.6 2.22h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l.81-.81a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7 2 2 0 0 1 1.72 2.01z" />
                                    </svg>
                                    <input type="tel" id="phone" name="phone" class="form-control-custom"
                                        placeholder="+91 98765 43210" />
                                </div>
                            </div>

                            <!-- ── Security ── -->
                            <div class="form-section-title">Security</div>

                            <div class="form-group">
                                <label class="form-label" for="regPass">Password</label>
                                <div class="input-wrap">
                                    <svg class="input-icon" width="16" height="16" viewBox="0 0 24 24" fill="none"
                                        stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                        stroke-linejoin="round">
                                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                                        <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                                    </svg>
                                    <input type="password" id="regPass" name="password" class="form-control-custom"
                                        placeholder="Min. 8 characters" required minlength="8" />
                                </div>
                            </div>

                            <!-- Submit -->
                            <button type="submit" class="btn-primary-custom">
                                <span>Create Account ✦</span>
                            </button>

                            <p class="auth-footer">
                                Already have an account? <a href="/">Sign in</a>
                            </p>

                        </form>
            </div>
        </main>

    </div>

</body>

</html>